# ============================================================================
# INSTRUÇÕES DE CONFIGURAÇÃO SEGURA
# ============================================================================
#
# 1. CRIE UM NOVO ARQUIVO CHAMADO ".env" (sem o ".example")
# 2. COPIE AS VARIÁVEIS ABAIXO
# 3. SUBSTITUA OS VALORES PELAS SUAS CHAVES REAIS
# 4. NUNCA COMMITE O ARQUIVO ".env" NO GIT (já está no .gitignore)
#
# Para obter suas chaves:
#
# Google Gemini API Key:
#   - Acesse: https://aistudio.google.com/app/apikey
#   - Clique em "Create API Key"
#   - Clique em "Create API Key in new project"
#   - Copie e cole abaixo
#
# GitHub Token:
#   - Acesse: https://github.com/settings/tokens
#   - Clique em "Generate new token (classic)"
#   - Selecione escopo: "repo" (acesso a repositórios públicos)
#   - Copie e cole abaixo
#
# ============================================================================

# Sua chave de API do Google Gemini
# Obtém informações: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=sua_chave_gemini_aqui

# Seu token de autenticação do GitHub
# Obtém informações: https://github.com/settings/tokens
GITHUB_TOKEN=seu_token_github_aqui
